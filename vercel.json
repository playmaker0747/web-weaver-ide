{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "public": false,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/:path*(svg|jpg|jpeg|png|gif|ico|css|js|webmanifest|woff|woff2)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, immutable, max-age=31536000"
        }
      ]
    }
  ]
}
